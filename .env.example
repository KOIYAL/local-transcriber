# 1回のアップロード上限 (MB)
MAX_UPLOAD_MB=2048

# CPU / CUDA を明示する場合に指定。通常は auto のままで構いません。
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# Hugging Face から取得済みの faster-whisper 形式モデルを使う場合に指定。
# 例: C:\models\faster-whisper-small
WHISPER_LOCAL_MODEL=

# モデルと処理済みファイルの保存先
WHISPER_MODEL_DIR=./data/models
TRANSCRIBER_DATA_DIR=./data

# true にするとアップロード元ファイルを処理後も残します。
KEEP_UPLOADS=false
